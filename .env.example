NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production after dokkit.co.za is connected:
# NEXT_PUBLIC_SITE_URL=https://dokkit.co.za

PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_PROCESS_URL=https://sandbox.payfast.co.za/eng/process
# Production PayFast endpoint:
# PAYFAST_PROCESS_URL=https://www.payfast.co.za/eng/process
PAYFAST_SKIP_IP_CHECK=false

RESEND_API_KEY=
RESEND_FROM_EMAIL=DokKit <orders@send.dokkit.co.za>
RESEND_REPLY_TO=support@dokkit.co.za
# Optional. Defaults to RESEND_REPLY_TO, then support@dokkit.co.za.
ORDER_NOTIFICATION_EMAIL=support@dokkit.co.za

# Optional but recommended. Keep this stable after launch, because it protects
# encrypted download access tokens used in customer emails.
DOWNLOAD_TOKEN_ENCRYPTION_KEY=
